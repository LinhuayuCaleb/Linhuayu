void MainWindow::paintEvent(QPaintEvent *) {
    setFocus();

    // 物理尺寸
    int physW = width();
    int physH = height();
    // 缩放因子（物理/逻辑）
    float scaleX = physW / float(logicalW);
    float scaleY = physH / float(logicalH);

    QPainter painter(this);
    painter.scale(scaleX, scaleY);   // 所有界面都缩放

    // ========================= MENU =========================
    if (gameState == MENU) {
        if (!menuBgReady) {
            QPixmap frame = renderGameFrame();   // 逻辑尺寸
            QImage blurred = blurImage(frame.toImage(), 6);
            menuBackground = QPixmap::fromImage(blurred);
            menuBgReady = true;
        }
        painter.drawPixmap(0, 0, logicalW, logicalH, menuBackground);
        painter.fillRect(0, 0, logicalW, logicalH, QColor(0, 0, 0, 120));

        painter.setPen(Qt::white);
        QFont font("Arial", 22);
        font.setBold(true);
        painter.setFont(font);

        QRect titleRect(0, logicalH/2 - 120, logicalW, 50);
        painter.drawText(titleRect, Qt::AlignCenter, "Caleb and Apple");

        // ================= 按钮（缩小居中） =================
        int btnW = 120;
        int btnH = 35;
        int centerX = logicalW / 2;

        startButton = QRect(centerX - btnW/2, logicalH/2 - 40, btnW, btnH);
        musicButton = QRect(centerX - btnW/2, logicalH/2 + 10, btnW, btnH);

        painter.setBrush(QColor(80, 200, 120));
        painter.setPen(Qt::black);
        painter.drawRect(startButton);
        painter.drawText(startButton, Qt::AlignCenter, "START");

        painter.setBrush(QColor(80, 120, 200));
        painter.drawRect(musicButton);
        painter.drawText(musicButton, Qt::AlignCenter, "MUSIC");

        return;
    }

    // ========================= SETTINGS =========================
    if (gameState == SETTINGS) {

        painter.fillRect(0, 0, logicalW, logicalH, QColor(30,30,30));

        painter.setPen(Qt::white);
        painter.drawRect(backButton);
        painter.drawText(backButton, Qt::AlignCenter, "BACK");

        // ========= 滑条 =========
        volumeBarRect = QRect(logicalW/2 - 140, logicalH/2, 280, 12);

        // 背景
        painter.setPen(Qt::NoPen);
        painter.setBrush(QColor(60,60,60));
        painter.drawRoundedRect(volumeBarRect, 6, 6);

        // 当前值
        QRect valueBar = volumeBarRect;
        valueBar.setWidth(volumeBarRect.width() * bgmVolume / 100.0);

        // ⭐渐变颜色（橙 -> 蓝）
        QLinearGradient grad(valueBar.topLeft(), valueBar.topRight());
        grad.setColorAt(0.0, QColor(255, 140, 0));
        grad.setColorAt(1.0, QColor(0, 170, 255));

        painter.setBrush(grad);
        painter.drawRoundedRect(valueBar, 6, 6);

        // ⭐动态数字颜色（音量越大越蓝）
        QColor textColor = QColor::fromHsv(200 - bgmVolume, 200, 255);
        painter.setPen(textColor);

        painter.drawText(volumeBarRect.x(),
                         volumeBarRect.y() - 10,
                         "BGM Volume");

        painter.drawText(volumeBarRect,
                         Qt::AlignCenter,
                         QString("%1%").arg(bgmVolume));

        return;
    }

    // ========================= PLAYING =========================
    if (layers.isEmpty()) return;

    // 绘制地图（已缩放，直接使用逻辑坐标）
    if (!insideHouse) {
        for (int l = 0; l < layers.size(); l++) {
            const auto &layer = layers[l];
            for (int i = 0; i < layer.size(); i++) {
                int id = layer[i];
                if (id == 0) continue;
                int dx = (i % mapWidth) * tileSize;
                int dy = (i / mapWidth) * tileSize;
                drawTile(painter, id, dx, dy);
            }
        }
    } else {
        // ⭐ 室内直接一张图
        static QPixmap indoorImg("indoors.png");

        if (!indoorImg.isNull()) {
            painter.drawPixmap(0, 0, logicalW, logicalH, indoorImg);
        } else {
            painter.fillRect(0, 0, logicalW, logicalH, QColor(40,40,40));
        }
    }

    // 绘制花朵（覆盖层）
    QPixmap flowerSheet("flower.png");
    if (!flowerSheet.isNull()) {
        for (int l = GROW_START_INDEX; l <= GROW_END_INDEX; ++l) {
            if (l >= layers.size()) continue;
            const auto &layer = layers[l];
            for (int i = 0; i < layer.size(); ++i) {
                int id = layer[i];
                if (id == 0) continue;
                if (i >= flowerActive.size() || !flowerActive[i]) continue;
                int local = id - 133;
                if (local < 0 || local > 8) continue;
                int tx = i % mapWidth;
                int ty = i / mapWidth;
                int baseX = tx * tileSize;
                int baseY = ty * tileSize;
                painter.drawPixmap(baseX + (tileSize-32)/2, baseY + (tileSize-32)/2,
                                   32, 32, flowerSheet, local*32, 0, 32, 32);
            }
        }
    }

    // 阴影
    painter.setBrush(QColor(0,0,0,80));
    painter.setPen(Qt::NoPen);
    painter.drawEllipse(playerX - 4, playerY + 10, 16, 6);

    // 玩家
    if (!playerSheet.isNull()) {
        int srcW = playerSheet.width() / 4;
        int srcH = playerSheet.height() / 4;
        int row = 0;
        bool mirror = false;
        if (currentDir == 0) row = 0;
        else if (currentDir == 3) row = 2;
        else if (currentDir == 2) { row = 1; mirror = true; }
        else if (currentDir == 1) row = 1;
        QRect sourceRect(currentFrame * srcW, row * srcH, srcW, srcH);
        QRect targetRect(playerX - 4, playerY - 4, 24, 24);
        if (mirror) {
            QImage img = playerSheet.copy(sourceRect).toImage();
            painter.drawImage(targetRect, img.mirrored(true,false));
        } else {
            painter.drawPixmap(targetRect, playerSheet, sourceRect);
        }
    }

    // 夜晚遮罩
    float darkness = 0.0f;
    if (timeOfDay > 500 && timeOfDay <= 800)
        darkness = (timeOfDay - 500) / 300.0f * 0.6f;
    else if (timeOfDay > 800)
        darkness = 0.85f;
    painter.setBrush(QColor(0,0,30, int(darkness * 220)));
    painter.setPen(Qt::NoPen);
    painter.drawRect(0, 0, logicalW, logicalH);

    // 表情
    if (showEmotion && currentEmotion) {
        QPixmap emotionPix = currentEmotion->currentPixmap().scaled(64, 64, Qt::KeepAspectRatio);
        painter.drawPixmap(playerX + 12 - emotionPix.width()/2,
                           playerY + 4 - emotionPix.height(),
                           emotionPix);
    }

    // UI按钮
    painter.setBrush(Qt::darkGray);
    painter.setPen(Qt::white);
    painter.drawRect(bagButton);
    painter.drawRect(exitButton);
    painter.drawRect(volumeButton);
    QString icon;
    if (bgmVolume == 0) icon = "🔇";
    else if (bgmVolume < 50) icon = "🔉";
    else icon = "🔊";
    painter.drawText(volumeButton, Qt::AlignCenter, icon);
    painter.drawText(bagButton, Qt::AlignCenter, "👜");
    painter.drawText(exitButton, Qt::AlignCenter, "⚙");

    // 音量面板
    if (showVolumePanel) {

        QRect panel(logicalW/2 - 120, logicalH/2 - 60, 240, 120);

        painter.setBrush(QColor(0,0,0,180));
        painter.setPen(Qt::white);
        painter.drawRect(panel);

        volumeBarRect = QRect(panel.x() + 20, panel.y() + 50, 200, 10);

        // 背景条
        painter.setBrush(Qt::darkGray);
        painter.drawRect(volumeBarRect);

        // 当前值
        QRect valueBar = volumeBarRect;
        valueBar.setWidth(volumeBarRect.width() * bgmVolume / 100.0);

        painter.setBrush(Qt::green);
        painter.drawRect(valueBar);

        painter.drawText(panel.x()+70, panel.y()+25,
                         QString("Volume: %1").arg(bgmVolume));
    }

    // 背包面板
    if (showInventory) {
        QRect bagPanel(logicalW/2 - 150, logicalH/2 - 120, 300, 240);
        painter.setBrush(QColor(30, 30, 70, 220));
        painter.setPen(Qt::white);
        painter.drawRect(bagPanel);
        painter.drawText(bagPanel.x() + 10, bagPanel.y() + 20, "🎒 Inventory");
        for (int i = 0; i < inventory.size(); ++i) {
            QString text;
            if (inventory[i].id == ITEM_FLOWER)
                text = "🌻 Flower x" + QString::number(inventory[i].count);
            else
                text = "Item x" + QString::number(inventory[i].count);
            painter.drawText(bagPanel.x() + 20, bagPanel.y() + 50 + i * 25, text);
        }
        if (inventory.isEmpty())
            painter.drawText(bagPanel.x() + 20, bagPanel.y() + 50, "(empty)");
        QRect closeBtn(bagPanel.right() - 30, bagPanel.top() + 5, 20, 20);
        painter.drawText(closeBtn, Qt::AlignCenter, "X");
    }

    // 退出菜单面板
    if (showExitMenu) {
        QRect menuPanel(logicalW/2 - 120, logicalH/2 - 80, 240, 160);
        painter.setBrush(QColor(50, 50, 50, 230));
        painter.setPen(Qt::white);
        painter.drawRect(menuPanel);
        painter.drawText(menuPanel.x() + 60, menuPanel.y() + 30, "Menu");
        QRect resumeBtn(menuPanel.x() + 20, menuPanel.y() + 60, 200, 35);
        QRect quitBtn(menuPanel.x() + 20, menuPanel.y() + 105, 200, 35);
        painter.drawRect(resumeBtn);
        painter.drawRect(quitBtn);
        painter.drawText(resumeBtn, Qt::AlignCenter, "Resume");
        painter.drawText(quitBtn, Qt::AlignCenter, "Back to Title");
    }
}

void MainWindow::onAnimationTimer() {
    if (isMoving)
        currentFrame = (currentFrame + 1) % 4;
    else
        currentFrame = 0;
    if (currentEmotion)
        currentEmotion->jumpToNextFrame();
    update();
}

void MainWindow::tryOpenDoor() {
    if (insideHouse) {
        insideHouse = false;
        playerX = currentDoor.x() * tileSize;
        playerY = currentDoor.y() * tileSize + 32;
        int index = currentDoor.y() * mapWidth + currentDoor.x();
        if (index < layers[1].size())
            layers[1][index] = getClosedDoor(layers[1][index]);
        update();
        return;
    }
    int centerTX = (playerX + 8) / tileSize;
    int centerTY = (playerY + 8) / tileSize;
    QVector<int> &houseLayer = layers[1];
    for (int y = -2; y <= 2; y++) {
        for (int x = -2; x <= 2; x++) {
            int tx = centerTX + x;
            int ty = centerTY + y;
            if (tx < 0 || ty < 0 || tx >= mapWidth || ty >= mapHeight)
                continue;
            int index = ty * mapWidth + tx;
            if (index < 0 || index >= houseLayer.size()) continue;
            int tileID = houseLayer[index];
            if (isClosedDoor(tileID)) {
                houseLayer[index] = getOpenedDoor(tileID);
                currentDoor = QPoint(tx, ty);
                insideHouse = true;
                playerX = indoorSpawn.x();
                playerY = indoorSpawn.y();
                update();
                return;
            }
        }
    }
}

void MainWindow::updatePlayer() {
    if (gameState != PLAYING) return;
    updateSpeedByTerrain();
    speed += (targetSpeed - speed) * 0.10;
    int targetX = playerX;
    int targetY = playerY;
    isMoving = false;
    if (keyW) { targetY -= speed; currentDir = 3; isMoving = true; }
    if (keyS) { targetY += speed; currentDir = 0; isMoving = true; }
    if (keyA) { targetX -= speed; currentDir = 1; isMoving = true; }
    if (keyD) { targetX += speed; currentDir = 2; isMoving = true; }
    if (canMoveTo(targetX, playerY)) playerX = targetX;
    if (canMoveTo(playerX, targetY)) playerY = targetY;
    update();
}

QPixmap MainWindow::renderGameFrame() {
    // 返回逻辑尺寸的游戏画面（不含UI）
    QPixmap img(logicalW, logicalH);
    img.fill(Qt::black);
    QPainter p(&img);
    if (!insideHouse) {
        for (int l = 0; l < layers.size(); l++) {
            if (l == 1) continue; // 避开门层，与菜单原逻辑一致
            const auto &layer = layers[l];
            for (int i = 0; i < layer.size(); i++) {
                int id = layer[i];
                if (id == 0) continue;
                int dx = (i % mapWidth) * tileSize;
                int dy = (i / mapWidth) * tileSize;
                drawTile(p, id, dx, dy);
            }
        }
    }
    return img;
}

QImage MainWindow::blurImage(const QImage &source, int radius) {
    if (source.isNull()) return source;
    QImage result = source;
    for (int y = radius; y < source.height() - radius; y++) {
        for (int x = radius; x < source.width() - radius; x++) {
            int r = 0, g = 0, b = 0, count = 0;
            for (int ky = -radius; ky <= radius; ky++) {
                for (int kx = -radius; kx <= radius; kx++) {
                    QColor c(source.pixel(x + kx, y + ky));
                    r += c.red(); g += c.green(); b += c.blue();
                    count++;
                }
            }
            result.setPixelColor(x, y, QColor(r/count, g/count, b/count));
        }
    }
    return result;
}
