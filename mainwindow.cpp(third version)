#include "mainwindow.h"
#include <QPainter>
#include <QFile>
#include <QXmlStreamReader>
#include <QDebug>
#include <QKeyEvent>

MainWindow::MainWindow(QWidget *parent) : QWidget(parent)
{
    loadTMX();

    // 1. 加载精灵图 (请确保文件名 Caleb_and_apple.jpg 正确)
    if(!playerSheet.load("Caleb_Walk.png")) {
        qDebug() << "Cannot find Caleb_Walk.png";
    }
    setFocusPolicy(Qt::StrongFocus);

    // 2. 动画定时器：控制行走帧切换
    animTimer = new QTimer(this);
    connect(animTimer, &QTimer::timeout, this, &MainWindow::onAnimationTimer);
    animTimer->start(120); // 120毫秒切换一帧

    double scaleFactor=2.0;
    setFixedSize(mapWidth * tileSize*scaleFactor, mapHeight * tileSize*scaleFactor);
    // 在 MainWindow 构造函数里
    playerX = 100;
    playerY = 100;
    speed = 5;
    currentFrame = 0;
    currentDir = 0;
    isMoving = false;
    // 让窗口能接收键盘
    setFocusPolicy(Qt::StrongFocus);

    // 移动定时器（丝滑移动核心）
    moveTimer = new QTimer(this);
    connect(moveTimer, &QTimer::timeout, this, &MainWindow::updatePlayer);
    moveTimer->start(16); // 约60FPS
}

void MainWindow::loadTMX()
{
    QFile file("map.tmx");
    if (!file.open(QIODevice::ReadOnly)) return;

    QXmlStreamReader xml(&file);
    while (!xml.atEnd()) {
        xml.readNext();
        if (xml.isStartElement() && xml.name() == "data") {
            QString data = xml.readElementText();
            QStringList list = data.split(",");
            QVector<int> layer;
            for (QString s : list) {
                layer.append(s.trimmed().toInt());
            }
            layers.append(layer);
        }
    }
    file.close();
}

bool MainWindow::canMoveTo(int nextX, int nextY)
{
    int boxSize=12;
    int margin=2;
    // 1. 边界检测：防止小人走出地图边缘
    // 注意：这里比较的是原始像素坐标，不需要乘缩放倍数，因为坐标系已经整体 scale 了
    if (nextX < 0 || nextY < 0 ||
        nextX + boxSize+margin > mapWidth * tileSize ||
        nextY + boxSize+margin > mapHeight * tileSize) {
        return false;
    }

    QVector<QPoint> corners;
    corners << QPoint(nextX + margin, nextY + margin);
    corners << QPoint(nextX + boxSize, nextY + margin);
    corners << QPoint(nextX + margin, nextY + boxSize);
    corners << QPoint(nextX + boxSize, nextY + boxSize);

    int tx = (nextX + 8) / tileSize;
    int ty = (nextY + 8) / tileSize;

    for (const auto& layer : layers) {
        int index = ty * mapWidth + tx;
        if (index >= 0 && index < layer.size()) {
            int tileID = layer[index];

            // --- 核心调试点：在这里加打印 ---
            if (tileID != 0) {
                qDebug() << "角色位置 ID:" << tileID << "坐标:" << tx << ty;
            }

            // --- 临时修改：放宽限制 ---
            // 如果你不知道哪个是障碍物，先只拦截 ID 特别大的（比如房子/树）
            // 如果还是卡住，把下面这行改成 if (tileID > 1000) 试试
            // 在 canMoveTo 内部
            if (tileID == 0) continue; // 0 是透明/空，肯定能走
            // 调试用：先允许 1 到 10 的 ID 都能走（假设你的路面 ID 在这个范围内）
            if(tileID==29){
                return false;
            }
            if (tileID > 10) {
                return false; // 只有 ID 很大的瓦片（树、房子）才拦截
            }
        }
    }
    return true;
}

void MainWindow::keyPressEvent(QKeyEvent *event)
{
    if (event->isAutoRepeat()) return;

    if (event->key() == Qt::Key_W) keyW = true;
    if (event->key() == Qt::Key_S) keyS = true;
    if (event->key() == Qt::Key_A) keyA = true;
    if (event->key() == Qt::Key_D) keyD = true;
    if (event->key() == Qt::Key_E) {
        tryOpenDoor();
    }
}

void MainWindow::keyReleaseEvent(QKeyEvent *event)
{
    if (event->isAutoRepeat()) return;

    if (event->key() == Qt::Key_W) keyW = false;
    if (event->key() == Qt::Key_S) keyS = false;
    if (event->key() == Qt::Key_A) keyA = false;
    if (event->key() == Qt::Key_D) keyD = false;
}

void MainWindow::paintEvent(QPaintEvent *)
{
    QPainter painter(this);

    double scaleFactor = 2.0; // 放大倍数，2.0 代表放大一倍（16px 变 32px 视觉效果）
    painter.scale(scaleFactor, scaleFactor);
    // ------------------

    // 开启平滑缩放，防止放大后像素出现难看的锯齿
    painter.setRenderHint(QPainter::SmoothPixmapTransform);

    // --- 1. 绘制地图 ---
    QPixmap tileset("tiles.png");
    if (!tileset.isNull()) {
        int columns = tileset.width() / tileSize;
        for (int l = 0; l < layers.size(); l++) {
            const QVector<int>& layer = layers[l];
            for (int i = 0; i < layer.size(); i++) {
                int id = layer[i];
                if (id == 0) continue;
                id -= 1;
                int sx = (id % columns) * tileSize;
                int sy = (id / columns) * tileSize;
                int dx = (i % mapWidth) * tileSize;
                int dy = (i / mapWidth) * tileSize;
                painter.drawPixmap(dx, dy, tileset, sx, sy, tileSize, tileSize);
            }
        }
    }

    // --- 2. 绘制角色 (严格适配 16x16) ---
    if (!playerSheet.isNull()) {
        // 根据你提供的 4x4 精灵图进行切片
        int frameCols = 4; // 每行4帧动作
        int frameRows = 4; // 总共4行方向

        // 自动计算每一帧原始像素宽高
        int srcW = playerSheet.width() / frameCols;
        int srcH = playerSheet.height() / frameRows;

        // 在 paintEvent 绘制角色的部分
        int row = 0;
        bool shouldMirror = false;

        if (currentDir == 0) {      // 向下
            row = 0;
        } else if (currentDir == 3) { // 向上
            row = 2;
        } else if (currentDir == 2) { // 向右
            row = 1;
            shouldMirror = true; // 图片本来就朝右，不需要翻转
        } else if (currentDir == 1) { // 向左
            row = 1;
            shouldMirror = false;  // 关键：向左走时，把朝右的图翻转过去
        }

        // 定义原图裁剪矩形
        QRect sourceRect(currentFrame * srcW, row * srcH, srcW, srcH);

        // 渲染设置：建议比瓦片(16)稍微大一点点，看起来更丰满
        int renderSize = 24;
        int offset = (renderSize - 16) / 2;
        QRect targetRect(playerX - offset, playerY - offset, renderSize, renderSize);

        if (shouldMirror) {
            // 水平翻转处理左侧行走
            QImage frameImg = playerSheet.copy(sourceRect).toImage();
            QImage mirroredImg = frameImg.mirrored(true, false);
            painter.drawImage(targetRect, mirroredImg);
        } else {
            // 正常绘制其他方向
            painter.drawPixmap(targetRect, playerSheet, sourceRect);
        }
    }
}
//2. 确保动画逻辑正确
    //在你的定时器（QTimer）回调函数中，需要让 currentFrame 在 0 到 3 之间循环，这样小人才能“走”起来：
    // 在处理动画的 timerEvent 或 slot 中
void MainWindow::onAnimationTimer()
{
    if (isMoving) {
        // 这里的 % 4 严格对应你那张“走路16_2.jpg”横向的4张图
        currentFrame = (currentFrame + 1) % 4;
        update(); // 告诉 Qt 界面需要重新绘制，从而触发 paintEvent
    } else {
        // 当玩家松开按键，停止移动时
        // 强制切换回第 0 帧（通常是站立姿势），防止停在“迈步”的尴尬动作上
        if (currentFrame != 0) {
            currentFrame = 0;
            update();
        }
    }
}
void MainWindow::tryOpenDoor()
{
    int tx = playerX / tileSize;
    int ty = playerY / tileSize;

    // 面前一格
    if (currentDir == 0) ty += 1;      // 下
    else if (currentDir == 3) ty -= 1; // 上
    else if (currentDir == 1) tx -= 1; // 左
    else if (currentDir == 2) tx += 1; // 右

    int index = ty * mapWidth + tx;

    for (auto &layer : layers) {
        if (index >= 0 && index < layer.size()) {

            int tileID = layer[index];
            qDebug() << "面前tileID:" << tileID;

            // 👉 这里先用 50 测试
            if (tileID == 29) {
                layer[index] = 30; // 开门
                qDebug() << "开门成功!";
            }
        }
    }

    update();
}
void MainWindow::updatePlayer()
{
    int targetX = playerX;
    int targetY = playerY;

    isMoving = false;

    if (keyW) { targetY -= speed; currentDir = 3; isMoving = true; }
    if (keyS) { targetY += speed; currentDir = 0; isMoving = true; }
    if (keyA) { targetX -= speed; currentDir = 1; isMoving = true; }
    if (keyD) { targetX += speed; currentDir = 2; isMoving = true; }

    if (canMoveTo(targetX, playerY)) playerX = targetX;
    if (canMoveTo(playerX, targetY)) playerY = targetY;

    update();
}
void MainWindow::openDoor(int tx, int ty)
{
    int index = ty * mapWidth + tx;

    for (auto &layer : layers) {
        if (index >= 0 && index < layer.size()) {
            if (layer[index] == 29) {
                layer[index] = 30; // 开门后的tile
            }
        }
    }

    update();
}
