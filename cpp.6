MainWindow::MainWindow(QWidget *parent)
    : QWidget(parent)
{
    loadTMX();

    gameState = MENU;
    setFocusPolicy(Qt::StrongFocus);
    setFocus();

    // ================= MENU按钮 =================
    // 窗口原始像素大小，后面不再缩放 painter
    int logicalW = mapWidth * tileSize;
    int logicalH = mapHeight * tileSize;
    setFixedSize(logicalW, logicalH);   // 直接用 1:1 像素，不再乘2

    startButton = QRect(logicalW/2 - 80, logicalH/2 - 60, 160, 50);
    musicButton = QRect(logicalW/2 - 80, logicalH/2 + 10, 160, 50);

    // ================= 游戏UI按钮 =================
    bagButton   = QRect(10, 10, 50, 50);
    exitButton  = QRect(70, 10, 50, 50);
    volumeButton= QRect(130, 10, 50, 50);

    // 设置界面的返回按钮（记得在头文件里声明 QRect backButton;）
    backButton = QRect(logicalW/2 - 40, logicalH - 60, 80, 40);

    tileset.load("tiles.png");
    columns = tileset.width() / tileSize;

    // 玩家贴图
    if (!playerSheet.load("Caleb_Walk.png")) {
        qDebug() << "Cannot find Caleb_Walk.png";
    }

    // ===== BGM =====
    bgmPlayer = new QMediaPlayer(this);
    audioOutput = new QAudioOutput(this);
    bgmPlayer->setAudioOutput(audioOutput);
    audioOutput->setVolume(bgmVolume/100.0);

    QString path = QCoreApplication::applicationDirPath() + "/bgm.mp3";
    bgmPlayer->setSource(QUrl::fromLocalFile(path));

    // 不自动播放，由用户从菜单控制
    // bgmPlayer->play();  // 移除自动播放

    // =========================
    // 植物生长数组初始化 ⭐
    // =========================
    int totalTiles = mapWidth * mapHeight;
    plantTime.resize(totalTiles);
    plantTime.fill(0);               // 关键：必须置零

    flowerActive.resize(totalTiles);
    std::fill(flowerActive.begin(), flowerActive.end(), false);

    // =========================
    // 室内房间居中
    // =========================
    int roomW = 280;
    int roomH = 180;
    int roomX = (logicalW - roomW) / 2;
    int roomY = (logicalH - roomH) / 2;
    indoorBounds = QRect(roomX, roomY, roomW, roomH);
    indoorSpawn = QPoint(indoorBounds.center().x(), indoorBounds.center().y());

    // =========================
    // 动画
    // =========================
    animTimer = new QTimer(this);
    connect(animTimer, &QTimer::timeout, this, &MainWindow::onAnimationTimer);
    animTimer->start(120);

    QTimer* timeTimer = new QTimer(this);
    connect(timeTimer, &QTimer::timeout, this, [=]() {
        timeOfDay += 1;
        if (timeOfDay > 1000)
            timeOfDay = 0;

        isNight = (timeOfDay > 600);
        update();
    });
    timeTimer->start(50);

    // =========================
    // 移动
    // =========================
    moveTimer = new QTimer(this);
    connect(moveTimer, &QTimer::timeout, this, &MainWindow::updatePlayer);
    moveTimer->start(16);
    setFocus();

    // =========================
    // GIF表情加载（白天/夜晚）
    // =========================
    emotionItems.append({new QMovie("happy.gif"), "happy", false, false});
    emotionItems.append({new QMovie("funny.gif"), "funny", false, false});
    emotionItems.append({new QMovie("hug.gif"), "hug", false, false});
    emotionItems.append({new QMovie("tired.gif"), "tired", false, false});
    emotionItems.append({new QMovie("comfort.gif"), "comfort", false, false});
    emotionItems.append({new QMovie("celebrate.gif"), "celebrate", false, false});
    emotionItems.append({new QMovie("goodmorning.gif"), "goodmorning", true, false});
    emotionItems.append({new QMovie("goodnight.gif"), "goodnight", false, true});

    // =========================
    // 表情随机刷新
    // =========================
    emotionTimer = new QTimer(this);
    connect(emotionTimer, &QTimer::timeout, this, [=]() {
        QVector<EmotionItem> pool;
        for (const auto &e : emotionItems) {
            if (isNight && e.dayOnly) continue;
            if (!isNight && e.nightOnly) continue;
            pool.append(e);
        }
        if (pool.isEmpty()) return;

        int index = QRandomGenerator::global()->bounded(pool.size());

        // 停止旧的动画 ⭐
        if (currentEmotion) {
            currentEmotion->stop();
        }

        currentEmotion = pool[index].movie;
        if (currentEmotion)
            currentEmotion->start();

        showEmotion = true;
        update();
    });
    emotionTimer->start(3000);

    // =========================
    // 农田生长定时器
    // =========================
    farmTimer = new QTimer(this);
    connect(farmTimer, &QTimer::timeout, this, [this]() {
        if (GROW_START_INDEX >= layers.size() || GROW_END_INDEX >= layers.size())
            return;

        const qint64 now = QDateTime::currentMSecsSinceEpoch();
        const qint64 stageDurationMs = 15 * 1000;   // 每阶段15秒
        const qint64 failShowMs = 10 * 1000;        // 枯萎持续10秒

        for (int i = 0; i < plantTime.size(); ++i) {
            if (plantTime[i] == 0) continue;

            qint64 elapsed = now - plantTime[i];
            int stage = static_cast<int>(elapsed / stageDurationMs);
            if (stage > MAX_GROW_STAGE) stage = MAX_GROW_STAGE;

            // 清空所有生长层
            for (int l = GROW_START_INDEX; l <= GROW_END_INDEX; ++l)
                layers[l][i] = 0;

            if (stage == MAX_GROW_STAGE) {
                qint64 failEndTime = MAX_GROW_STAGE * stageDurationMs + failShowMs;
                if (elapsed >= failEndTime) {
                    plantTime[i] = 0;
                    flowerActive[i] = false;   // ⭐ 恢复可种植
                    continue;
                } else {
                    if (FAIL_LAYER_INDEX < layers.size())
                        layers[FAIL_LAYER_INDEX][i] = 141;
                }
            } else {
                int targetLayer = GROW_START_INDEX + stage;
                if (targetLayer <= GROW_END_INDEX)
                    layers[targetLayer][i] = 133 + stage;
                flowerActive[i] = true;   // ⭐ 保持激活
            }
        }
        update();
    });
    farmTimer->start(1000);
}

// 析构函数释放 QMovie
MainWindow::~MainWindow() {
    for (auto &item : emotionItems) {
        delete item.movie;
    }
}

void MainWindow::loadTMX() {
    QFile file("map.tmx");
    if (!file.open(QIODevice::ReadOnly))
        return;

    QXmlStreamReader xml(&file);
    while (!xml.atEnd()) {
        xml.readNext();
        if (xml.isStartElement()) {
            // ⭐ 解析地图宽高
            if (xml.name() == "map") {
                mapWidth  = xml.attributes().value("width").toInt();
                mapHeight = xml.attributes().value("height").toInt();
            }
            if (xml.name() == "data") {
                QString data = xml.readElementText();
                QStringList list = data.split(",");
                QVector<int> layer;
                for (const QString &s : list) {
                    layer.append(s.trimmed().toInt());
                }
                layers.append(layer);
            }
        }
    }
    file.close();

    // 如果 TMX 中未找到，可设默认值（比如 50x50）
    if (mapWidth == 0) mapWidth = 50;
    if (mapHeight == 0) mapHeight = 50;
}

bool MainWindow::isClosedDoor(int id) {
    return id == 85 || id == 89;
}
bool MainWindow::isOpenedDoor(int id) {
    return id == 74 || id == 78;
}
int MainWindow::getOpenedDoor(int closedID) {
    if (closedID == 85) return 74;
    if (closedID == 89) return 78;
    return closedID;
}
int MainWindow::getClosedDoor(int openID) {
    if (openID == 74) return 85;
    if (openID == 78) return 89;
    return openID;
}

bool MainWindow::canMoveTo(int nextX, int nextY) {
    // ⭐ 室内碰撞（保持原有逻辑，但绝对不再修改玩家坐标）
    if (insideHouse) {
        QRect playerRect(nextX, nextY, 16, 16);
        return indoorBounds.contains(playerRect);
        // 移除原来修改 playerX, playerY 的代码
    }

    int size = 16;
    // 地图边界
    if (nextX < 0 || nextY < 0 ||
        nextX + size > mapWidth * tileSize ||
        nextY + size > mapHeight * tileSize)
        return false;

    QVector<QPoint> points = {
        {nextX, nextY},
        {nextX+15, nextY},
        {nextX, nextY+15},
        {nextX+15, nextY+15}
    };

    for (const auto &p : points) {
        int tx = p.x() / tileSize;
        int ty = p.y() / tileSize;
        int index = ty * mapWidth + tx;

        // 房屋层碰撞
        if (1 < layers.size()) {
            const auto &houseLayer = layers[1];
            if (index >= 0 && index < houseLayer.size()) {
                int tileID = houseLayer[index];
                if (isClosedDoor(tileID)) return false;
                if (isOpenedDoor(tileID)) continue;
                if (tileID >= 49) return false;
            }
        }
        // 树木层碰撞
        if (3 < layers.size()) {
            const auto &treeLayer = layers[3];
            if (index >= 0 && index < treeLayer.size()) {
                if (treeLayer[index] != 0) return false;
            }
        }
    }
    return true;
}

void MainWindow::updateSpeedByTerrain() {
    if (insideHouse) {
        targetSpeed = 2.0;
        return;
    }
    int tx = (playerX + 8) / tileSize;
    int ty = (playerY + 8) / tileSize;
    int index = ty * mapWidth + tx;
    targetSpeed = 2.0;

    if (0 < layers.size()) {
        const auto &grass = layers[0];
        if (index < grass.size() && grass[index] == 1)
            targetSpeed = 1.5;
    }
    if (2 < layers.size()) {
        const auto &road = layers[2];
        if (index < road.size() && road[index] != 0)
            targetSpeed = 2.8;
    }
}

void MainWindow::mousePressEvent(QMouseEvent *event) {
    QPoint pos = event->pos();   // 现在窗口是 1:1 像素，无需转换

    for (int i = 0; i < uiButtons.size(); i++) {
        if (uiButtons[i].contains(pos)) {
            QString name = uiTexts[i];
            if (name == "START") gameState = PLAYING;
            if (name == "MUSIC") gameState = SETTINGS;
            if (name == "BAG") showInventory = !showInventory;
            if (name == "SET") showExitMenu = true;
            if (name == "VOL") showVolumePanel = !showVolumePanel;
            update();
            setFocus();
            return;
        }
    }

    // ⭐ 音量面板按钮
    if (showVolumePanel) {
        QRect panel(logicalW()/2 - 120, logicalH()/2 - 60, 240, 120);  // 使用成员变量记录窗口大小
        QRect minus(panel.x()+20, panel.y()+40, 60, 40);
        QRect plus(panel.x()+160, panel.y()+40, 60, 40);
        if (minus.contains(pos)) {
            bgmVolume = qMax(0, bgmVolume - 5);
            audioOutput->setVolume(bgmVolume/100.0);
            update();
            setFocus();
            return;
        }
        if (plus.contains(pos)) {
            bgmVolume = qMin(100, bgmVolume + 5);
            audioOutput->setVolume(bgmVolume/100.0);
            update();
            setFocus();
            return;
        }
    }
    // 关闭背包
    if (showInventory) {
        int w = width(), h = height();
        QRect bagPanel(w/2 - 150, h/2 - 120, 300, 240);
        QRect closeBtn(bagPanel.right() - 30, bagPanel.top() + 5, 20, 20);
        if (closeBtn.contains(pos)) {
            showInventory = false;
            update();
            setFocus();
            return;
        }
    }

    // 退出菜单按钮
    if (showExitMenu) {
        int w = width(), h = height();
        QRect menuPanel(w/2 - 120, h/2 - 80, 240, 160);
        QRect resumeBtn(menuPanel.x() + 20, menuPanel.y() + 60, 200, 35);
        QRect quitBtn(menuPanel.x() + 20, menuPanel.y() + 105, 200, 35);

        if (resumeBtn.contains(pos)) {
            showExitMenu = false;
            update();
            setFocus();
            return;
        }
        if (quitBtn.contains(pos)) {
            showExitMenu = false;
            gameState = MENU;
            menuBgReady = false;          // 返回菜单时重新生成模糊背景
            update();
            setFocus();
            return;
        }
    }

    // ⭐ 设置界面返回按钮
    if (gameState == SETTINGS && backButton.contains(pos)) {
        gameState = MENU;
        update();
        setFocus();
        return;
    }
}

void MainWindow::keyPressEvent(QKeyEvent *event) {
    if (gameState != PLAYING) {
        if (event->key() == Qt::Key_Return) {
            gameState = PLAYING;
            update();
        }
        return;
    }
    if (event->isAutoRepeat()) return;

    if (event->key() == Qt::Key_W) keyW = true;
    if (event->key() == Qt::Key_S) keyS = true;
    if (event->key() == Qt::Key_A) keyA = true;
    if (event->key() == Qt::Key_D) keyD = true;

    if (event->key() == Qt::Key_E) tryOpenDoor();

    if (event->key() == Qt::Key_N) {
        isNight = !isNight;
        timeOfDay = isNight ? 800 : 200;
        update();
    }

    if (event->key() == Qt::Key_G) {
        if (layers.size() <= BEFORE_LAYER_INDEX) return;
        int tx = (playerX + 8) / tileSize;
        int ty = (playerY + 8) / tileSize;
        int index = ty * mapWidth + tx;
        if (index < 0 || index >= layers[BEFORE_LAYER_INDEX].size()) return;
        if (layers[BEFORE_LAYER_INDEX][index] == 0) return;

        // 清理旧花
        for (int l = GROW_START_INDEX; l <= GROW_END_INDEX; ++l)
            if (l < layers.size())
                layers[l][index] = 0;

        flowerActive[index] = true;
        plantTime[index] = QDateTime::currentMSecsSinceEpoch();
        layers[GROW_START_INDEX][index] = 133;
        update();
    }

    if (event->key() == Qt::Key_H) {
        // ⭐ 收获周围所有成熟花朵
        int cx = (playerX + 8) / tileSize;
        int cy = (playerY + 8) / tileSize;
        bool harvested = false;

        for (int dy = -1; dy <= 1; ++dy) {
            for (int dx = -1; dx <= 1; ++dx) {
                int nx = cx + dx;
                int ny = cy + dy;
                if (nx < 0 || ny < 0 || nx >= mapWidth || ny >= mapHeight)
                    continue;
                int index = ny * mapWidth + nx;
                if (index < 0 || index >= plantTime.size()) continue;
                if (plantTime[index] == 0) continue;

                qint64 elapsed = QDateTime::currentMSecsSinceEpoch() - plantTime[index];
                int stage = elapsed / (15 * 1000);
                if (stage >= 6) {   // 成熟阶段6
                    // 加入背包
                    bool found = false;
                    for (auto &it : inventory) {
                        if (it.id == ITEM_FLOWER) {
                            it.count++;
                            found = true;
                            break;
                        }
                    }
                    if (!found) inventory.push_back({ITEM_FLOWER, 1});

                    // 清除地图花
                    for (int l = GROW_START_INDEX; l <= GROW_END_INDEX; ++l)
                        if (l < layers.size())
                            layers[l][index] = 0;
                    plantTime[index] = 0;
                    flowerActive[index] = false;
                    harvested = true;
                }
            }
        }
        if (harvested) update();
        // 移除 return，可继续处理其他逻辑
    }

    if (event->key() == Qt::Key_B) {
        showInventory = !showInventory;
        update();
    }
}

void MainWindow::keyReleaseEvent(QKeyEvent *event) {
    if (event->isAutoRepeat()) return;
    if (event->key() == Qt::Key_W) keyW = false;
    if (event->key() == Qt::Key_S) keyS = false;
    if (event->key() == Qt::Key_A) keyA = false;
    if (event->key() == Qt::Key_D) keyD = false;
}

void MainWindow::drawTile(QPainter &painter, int id, int dx, int dy) {
    if (id <= 0) return;
    int realID = id - 1;
    int sx = (realID % columns) * tileSize;
    int sy = (realID / columns) * tileSize;
    painter.drawPixmap(dx, dy, tileset, sx, sy, tileSize, tileSize);
}

