    int currentDir = 0;     // 0:下, 1:左, 2:右, 3:上
    bool isMoving = false;
    QTimer *animTimer;

    // 精灵图切片参数 (针对该图片测量)
    const int spriteW = 48; // 原图中单个角色的宽度
    const int spriteH = 50; // 原图中单个角色的高度
